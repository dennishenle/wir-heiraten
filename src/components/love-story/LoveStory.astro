---
const stories = [
	{
		image: "https://images.unsplash.com/photo-1522673607200-164d1b6ce486?w=600&h=400&fit=crop",
		alt: "Wie wir uns kennenlernten",
		title: "Wie alles begann",
		text: `Es war ein ganz normaler Sommertag, als sich unsere Wege zum ersten Mal kreuzten. 
			Ich hatte Lust auf eine Quarktasche und spazierte in den Netto um dort die Theke der Bäckerei zu begutachten.
			Zu meiner Überraschung fand ich leider keine Quarktasche, aber eine überaus süße Verkäufering mit einem wundervollen Lächeln.
			Ich bemerkte direkt, dass sie etwas besonderes an sich hatte und konnte nicht anders, als nach ihrem Facebook Profil zu fragen
			um sie ein paar Tage später auf ein Date einzuladen.
			Und so begann unsere Geschichte. - Dennis`,
	},
	{
		image: "https://images.unsplash.com/photo-1515934751635-c81c6bc9a2d8?w=600&h=400&fit=crop",
		alt: "Der Heiratsantrag",
		title: "Der Antrag",
		text: `Nach Jahren voller gemeinsamer Abenteuer und unvergesslicher Momente
			war es an der Zeit, den nächsten Schritt zu wagen. An einem
			wunderschönen Abend unter dem Sternenhimmel kam dann die große
			Frage — und natürlich war die Antwort ein überglückliches Ja!
			Seitdem planen wir voller Freude den schönsten Tag unseres Lebens.`,
	},
];
---

<section id="love-story" class="section-padding bg-cream-dark">
	<div class="mx-auto max-w-5xl">
		<h2 class="section-title">Unsere Geschichte</h2>
		<p class="mx-auto mb-4 max-w-xl text-center text-text-light">
			Jede Liebesgeschichte ist schön, aber unsere ist unsere Liebste.
		</p>

		<!-- decorative heart divider -->
		<div class="mb-16 flex items-center justify-center gap-4">
			<span class="h-px w-12 bg-primary-light"></span>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				viewBox="0 0 24 24"
				fill="currentColor"
				class="size-5 text-primary"
			>
				<path
					d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"
				></path>
			</svg>
			<span class="h-px w-12 bg-primary-light"></span>
		</div>

		<div class="grid gap-16 md:grid-cols-2 md:gap-12">
			{
				stories.map((story) => (
					<article class="group">
						<div class="overflow-hidden rounded-2xl shadow-sm">
							<img
								src={story.image}
								alt={story.alt}
								class="aspect-3/2 w-full object-cover transition-transform duration-500 group-hover:scale-105"
								loading="lazy"
							/>
						</div>
						<h3 class="mt-6 font-heading text-2xl font-semibold text-text">
							{story.title}
						</h3>
						<p class="mt-3 leading-relaxed text-text-light">
							{story.text}
						</p>
					</article>
				))
			}
		</div>
	</div>
</section>
