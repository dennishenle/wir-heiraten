---
import HeartDivider from "./HeartDivider.astro";
import StoryCard from "./StoryCard.astro";
import { stories } from "./stories.ts";
---

<section id="story" class="section-padding bg-cream-dark">
	<div class="mx-auto max-w-5xl">
		<h2 class="section-title">Unsere Geschichte</h2>
		<p class="mx-auto mb-4 max-w-xl text-center text-text-light">
			Jede Liebesgeschichte ist schön, aber unsere ist unsere Liebste.
		</p>

		<HeartDivider />

		<div class="grid gap-16 md:grid-cols-2 md:gap-12">
			{
				stories.map((story) => (
					<StoryCard
						image={story.image}
						alt={story.alt}
						title={story.title}
						text={story.text}
						author={story.author}
					/>
				))
			}
		</div>
	</div>
</section>
