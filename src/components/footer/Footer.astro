---
const year = new Date().getFullYear();
---

<footer class="bg-text px-6 py-10 text-center text-cream/80">
	<p class="mb-2 font-heading text-lg text-cream">Svenja & Dennis</p>
	<p class="text-sm">&copy; {year} &mdash; Mit Liebe gemacht</p>
</footer>

<!-- Back to top button -->
<button
	id="back-to-top"
	aria-label="Nach oben scrollen"
	class="fixed right-6 bottom-6 z-50 flex h-12 w-12 translate-y-4 items-center justify-center rounded-full bg-primary text-cream opacity-0 shadow-lg transition-all duration-300 hover:bg-primary-light"
>
	<svg
		xmlns="http://www.w3.org/2000/svg"
		class="h-5 w-5"
		fill="none"
		viewBox="0 0 24 24"
		stroke="currentColor"
		stroke-width="2.5"
	>
		<path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"
		></path>
	</svg>
</button>

<script>
	const btn = document.getElementById("back-to-top")!;

	window.addEventListener("scroll", () => {
		if (window.scrollY > 400) {
			btn.classList.remove("opacity-0", "translate-y-4");
			btn.classList.add("opacity-100", "translate-y-0");
		} else {
			btn.classList.remove("opacity-100", "translate-y-0");
			btn.classList.add("opacity-0", "translate-y-4");
		}
	});

	btn.addEventListener("click", () => {
		window.scrollTo({ top: 0, behavior: "smooth" });
	});
</script>
