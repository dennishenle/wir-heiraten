---
import HeaderLogo from "./HeaderLogo.astro";
import DesktopNav from "./DesktopNav.astro";
import DarkModeToggle from "./DarkModeToggle.astro";
import MobileHamburger from "./MobileHamburger.astro";
import MobileMenu from "./MobileMenu.astro";
---

<header
    id="header"
    class="group/header fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
    <nav class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
        <HeaderLogo />
        <DesktopNav />
        <div class="hidden xl:block">
            <DarkModeToggle />
        </div>
        <MobileHamburger />
    </nav>
</header>

<MobileMenu />

<script>
    const header = document.getElementById("header")!;

    window.addEventListener("scroll", () => {
        if (window.scrollY > 50) {
            header.classList.add(
                "scrolled",
                "bg-cream/90",
                "backdrop-blur-md",
                "shadow-sm",
            );
        } else {
            header.classList.remove(
                "scrolled",
                "bg-cream/90",
                "backdrop-blur-md",
                "shadow-sm",
            );
        }
    });
</script>
