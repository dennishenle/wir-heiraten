---
import HeartDivider from "../love-story/HeartDivider.astro";
import RSVPForm from "./RSVPForm.astro";
import RSVPSuccess from "./RSVPSuccess.astro";
---

<section id="rsvp" class="section-padding bg-cream">
	<div class="mx-auto max-w-2xl">
		<h2 class="section-title">Zusagen</h2>
		<p class="mx-auto mb-4 max-w-xl text-center text-text-light">
			Bitte lasst uns bis zum 1. Juli wissen, ob ihr dabei sein könnt.
		</p>

		<HeartDivider />

		<RSVPForm />
		<RSVPSuccess />
	</div>
</section>
