---
import HeartDivider from "../love-story/HeartDivider.astro";
import { mealOptions, attendanceOptions } from "./rsvpData";
---

<section id="rsvp" class="section-padding bg-cream">
	<div class="mx-auto max-w-2xl">
		<h2 class="section-title">RSVP</h2>
		<p class="mx-auto mb-4 max-w-xl text-center text-text-light">
			Bitte lasst uns bis zum 1. Juni wissen, ob ihr dabei sein könnt.
		</p>

		<HeartDivider />

		<form id="rsvp-form" class="space-y-6" novalidate>
			<!-- Name -->
			<div>
				<label
					for="rsvp-name"
					class="mb-1 block text-sm font-semibold text-text"
				>
					Vollständiger Name <span class="text-primary">*</span>
				</label>
				<input
					type="text"
					id="rsvp-name"
					name="name"
					required
					class="w-full rounded-lg border border-cream-dark bg-white px-4 py-2.5 text-text transition focus:border-primary focus:ring-2 focus:ring-primary-light focus:outline-none"
				/>
				<p class="mt-1 hidden text-sm text-primary" data-error="name">
					Bitte gib deinen Namen ein.
				</p>
			</div>

			<!-- Email -->
			<div>
				<label
					for="rsvp-email"
					class="mb-1 block text-sm font-semibold text-text"
				>
					E-Mail-Adresse <span class="text-primary">*</span>
				</label>
				<input
					type="email"
					id="rsvp-email"
					name="email"
					required
					class="w-full rounded-lg border border-cream-dark bg-white px-4 py-2.5 text-text transition focus:border-primary focus:ring-2 focus:ring-primary-light focus:outline-none"
				/>
				<p class="mt-1 hidden text-sm text-primary" data-error="email">
					Bitte gib eine gültige E-Mail-Adresse ein.
				</p>
			</div>

			<!-- Number of Guests -->
			<div>
				<label
					for="rsvp-guests"
					class="mb-1 block text-sm font-semibold text-text"
				>
					Anzahl der Gäste <span class="text-primary">*</span>
				</label>
				<input
					type="number"
					id="rsvp-guests"
					name="guests"
					min="1"
					max="10"
					value="1"
					required
					class="w-full rounded-lg border border-cream-dark bg-white px-4 py-2.5 text-text transition focus:border-primary focus:ring-2 focus:ring-primary-light focus:outline-none"
				/>
				<p class="mt-1 hidden text-sm text-primary" data-error="guests">
					Bitte gib die Anzahl der Gäste ein.
				</p>
			</div>

			<!-- Attendance -->
			<fieldset>
				<legend class="mb-2 text-sm font-semibold text-text">
					Teilnahme <span class="text-primary">*</span>
				</legend>
				<div class="flex flex-wrap gap-6">
					{
						attendanceOptions.map((opt) => (
							<label class="flex cursor-pointer items-center gap-2 text-text">
								<input
									type="radio"
									name="attendance"
									value={opt.value}
									required
									class="size-4 accent-primary"
								/>
								{opt.label}
							</label>
						))
					}
				</div>
				<p
					class="mt-1 hidden text-sm text-primary"
					data-error="attendance"
				>
					Bitte wähle eine Option.
				</p>
			</fieldset>

			<!-- Meal Selection -->
			<div>
				<label
					for="rsvp-meal"
					class="mb-1 block text-sm font-semibold text-text"
				>
					Menüauswahl <span class="text-primary">*</span>
				</label>
				<select
					id="rsvp-meal"
					name="meal"
					required
					class="w-full rounded-lg border border-cream-dark bg-white px-4 py-2.5 text-text transition focus:border-primary focus:ring-2 focus:ring-primary-light focus:outline-none"
				>
					{
						mealOptions.map((opt) => (
							<option value={opt.value}>{opt.label}</option>
						))
					}
				</select>
				<p class="mt-1 hidden text-sm text-primary" data-error="meal">
					Bitte wähle ein Menü.
				</p>
			</div>

			<!-- Dietary Restrictions -->
			<div>
				<label
					for="rsvp-dietary"
					class="mb-1 block text-sm font-semibold text-text"
				>
					Unverträglichkeiten / Allergien
				</label>
				<textarea
					id="rsvp-dietary"
					name="dietary"
					rows="2"
					class="w-full rounded-lg border border-cream-dark bg-white px-4 py-2.5 text-text transition focus:border-primary focus:ring-2 focus:ring-primary-light focus:outline-none"
				></textarea>
			</div>

			<!-- Special Message -->
			<div>
				<label
					for="rsvp-message"
					class="mb-1 block text-sm font-semibold text-text"
				>
					Nachricht an das Brautpaar
				</label>
				<textarea
					id="rsvp-message"
					name="message"
					rows="3"
					class="w-full rounded-lg border border-cream-dark bg-white px-4 py-2.5 text-text transition focus:border-primary focus:ring-2 focus:ring-primary-light focus:outline-none"
				></textarea>
			</div>

			<!-- Submit -->
			<div class="text-center">
				<button
					type="submit"
					class="rounded-full bg-primary px-10 py-3 font-semibold text-white transition hover:bg-primary-light focus:ring-2 focus:ring-primary-light focus:outline-none"
				>
					Antwort senden
				</button>
			</div>
		</form>

		<!-- Success message (hidden by default) -->
		<div
			id="rsvp-success"
			class="mt-8 hidden rounded-xl bg-white p-8 text-center shadow-md"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				viewBox="0 0 24 24"
				fill="currentColor"
				class="mx-auto mb-4 size-12 text-primary"
			>
				<path
					fill-rule="evenodd"
					d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm13.36-1.814a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z"
					clip-rule="evenodd"></path>
			</svg>
			<h3 class="font-heading text-2xl font-bold text-text">
				Vielen Dank!
			</h3>
			<p class="mt-2 text-text-light">
				Deine Antwort wurde erfolgreich gesendet. Wir freuen uns auf
				dich!
			</p>
		</div>
	</div>
</section>

<script>
	const form = document.getElementById("rsvp-form") as HTMLFormElement;
	const success = document.getElementById("rsvp-success")!;
	const submitBtn = form.querySelector(
		'button[type="submit"]',
	) as HTMLButtonElement;

	const APPS_SCRIPT_URL =
		"https://script.google.com/macros/s/AKfycbykKqDPdYpDyhiI1LINSKf8_SKPjaPTlAmAMFWAci-KArDXUALomA6ZE8ZFvqgX7pqj/exec";

	function showError(name: string) {
		const el = form.querySelector(`[data-error="${name}"]`) as HTMLElement;
		el?.classList.remove("hidden");
	}

	function clearErrors() {
		form.querySelectorAll("[data-error]").forEach((el) => {
			el.classList.add("hidden");
		});
	}

	form.addEventListener("submit", async (e) => {
		e.preventDefault();
		clearErrors();

		const data = new FormData(form);
		let valid = true;

		if (!data.get("name")?.toString().trim()) {
			showError("name");
			valid = false;
		}

		const email = data.get("email")?.toString().trim() ?? "";
		if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
			showError("email");
			valid = false;
		}

		const guests = Number(data.get("guests"));
		if (!guests || guests < 1) {
			showError("guests");
			valid = false;
		}

		if (!data.get("attendance")) {
			showError("attendance");
			valid = false;
		}

		if (!data.get("meal")) {
			showError("meal");
			valid = false;
		}

		if (!valid) return;

		submitBtn.disabled = true;
		submitBtn.textContent = "Wird gesendet…";

		try {
			await fetch(APPS_SCRIPT_URL, {
				method: "POST",
				mode: "no-cors",
				headers: { "Content-Type": "text/plain" },
				body: JSON.stringify({
					name: data.get("name"),
					email: data.get("email"),
					guests: data.get("guests"),
					attendance: data.get("attendance"),
					meal: data.get("meal"),
					dietary: data.get("dietary") ?? "",
					message: data.get("message") ?? "",
				}),
			});
			form.classList.add("hidden");
			success.classList.remove("hidden");
		} catch (_) {
			submitBtn.disabled = false;
			submitBtn.textContent = "Antwort senden";
			alert("Es gab einen Fehler beim Senden. Bitte versuche es erneut.");
		}
	});
</script>
