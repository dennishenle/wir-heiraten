---
interface Props {
	emoji: string;
	title: string;
	description: string;
	url?: string;
}

const { emoji, title, description, url } = Astro.props;
---

<article
	class="rounded-2xl bg-white p-6 text-center shadow-sm transition-shadow duration-300 hover:shadow-md"
>
	<span class="text-3xl" role="img" aria-hidden="true">{emoji}</span>
	<h4 class="mt-3 font-heading text-lg font-semibold text-text">{title}</h4>
	<p class="mt-1 text-sm leading-relaxed text-text-light">{description}</p>
	{
		url && (
			<a
				href={url}
				target="_blank"
				rel="noopener noreferrer"
				class="mt-3 inline-flex items-center justify-center gap-1 text-sm font-medium text-primary transition-colors hover:text-primary-light"
				aria-label={`${title}: In Google Maps öffnen`}
			>
				In Google Maps öffnen
			</a>
		)
	}
</article>
