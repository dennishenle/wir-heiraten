---
interface Props {
	emoji: string;
	title: string;
	description: string;
}

const { emoji, title, description } = Astro.props;
---

<article
	class="rounded-2xl bg-white p-6 text-center shadow-sm transition-shadow duration-300 hover:shadow-md"
>
	<span class="text-3xl" role="img" aria-hidden="true">{emoji}</span>
	<h4 class="mt-3 font-heading text-lg font-semibold text-text">{title}</h4>
	<p class="mt-1 text-sm leading-relaxed text-text-light">{description}</p>
</article>
