---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { DetailItem } from "./details";
import DetailItemRow from "./DetailItemRow.astro";
import DirectionsButton from "./DirectionsButton.astro";

interface Props {
	image: ImageMetadata;
	alt: string;
	title: string;
	items: DetailItem[];
	directionsUrl: string;
}

const { image, alt, title, items, directionsUrl } = Astro.props;
---

<article
	class="group overflow-hidden rounded-2xl bg-cream shadow-sm transition-shadow duration-300 hover:shadow-md"
>
	<div class="overflow-hidden">
		<Image
			src={image}
			alt={alt}
			class="aspect-8/5 w-full object-cover transition-transform duration-500 group-hover:scale-105"
			loading="lazy"
		/>
	</div>

	<div class="p-6 sm:p-8">
		<h3 class="font-heading text-2xl font-semibold text-text">{title}</h3>

		<ul class="mt-5 space-y-4">
			{items.map((item) => <DetailItemRow {...item} />)}
		</ul>

		<DirectionsButton href={directionsUrl} />
	</div>
</article>
