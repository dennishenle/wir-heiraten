---
import HeartDivider from "../love-story/HeartDivider.astro";
import DetailCard from "./DetailCard.astro";
import { ceremony, reception } from "./details";
---

<section id="details" class="section-padding bg-cream-dark">
	<div class="mx-auto max-w-5xl">
		<h2 class="section-title">Hochzeitsdetails</h2>
		<p class="mx-auto mb-4 max-w-xl text-center text-text-light">
			Alles, was ihr über unseren besonderen Tag wissen müsst.
		</p>

		<HeartDivider />

		<div class="grid gap-12 md:grid-cols-2 md:gap-10">
			<DetailCard {...ceremony} />
			<DetailCard {...reception} />
		</div>
	</div>
</section>
