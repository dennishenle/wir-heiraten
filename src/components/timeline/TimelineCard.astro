---
interface Props {
	date: string;
	title: string;
	text: string;
	image: string;
	position: "left" | "right";
}

const { date, title, text, image, position } = Astro.props;
const isLeft = position === "left";
---

<div
	class:list={[
		"relative grid items-center gap-8 md:grid-cols-[1fr_auto_1fr]",
	]}
>
	{/* Left column */}
	<div
		class:list={[
			"md:text-right",
			isLeft ? "order-1" : "order-1 md:order-3 md:text-left",
		]}
	>
		{
			isLeft ? (
				<div>
					<span class="inline-block rounded-full bg-primary-light/30 px-4 py-1 font-heading text-sm font-semibold text-primary">
						{date}
					</span>
					<h3 class="mt-3 font-heading text-xl font-semibold text-text">
						{title}
					</h3>
					<p class="mt-2 leading-relaxed text-text-light">{text}</p>
				</div>
			) : (
				<div class="flex justify-center md:justify-end">
					<img
						src={image}
						alt={title}
						class="size-48 rounded-full object-cover shadow-md ring-4 ring-white md:size-40"
						loading="lazy"
					/>
				</div>
			)
		}
	</div>

	{/* Centre dot */}
	<div class="order-2 hidden md:flex md:flex-col md:items-center">
		<div
			class="size-4 rounded-full border-4 border-primary bg-white shadow-sm"
		>
		</div>
	</div>

	{/* Right column */}
	<div
		class:list={[
			isLeft ? "order-3" : "order-3 md:order-1 md:text-right",
		]}
	>
		{
			isLeft ? (
				<div class="flex justify-center md:justify-start">
					<img
						src={image}
						alt={title}
						class="size-48 rounded-full object-cover shadow-md ring-4 ring-white md:size-40"
						loading="lazy"
					/>
				</div>
			) : (
				<div>
					<span class="inline-block rounded-full bg-primary-light/30 px-4 py-1 font-heading text-sm font-semibold text-primary">
						{date}
					</span>
					<h3 class="mt-3 font-heading text-xl font-semibold text-text">
						{title}
					</h3>
					<p class="mt-2 leading-relaxed text-text-light">{text}</p>
				</div>
			)
		}
	</div>
</div>
