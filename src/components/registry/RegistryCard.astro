---
interface Props {
	name: string;
	imageUrl: string;
	href: string;
	linkLabel: string;
}

const { name, imageUrl, href, linkLabel } = Astro.props;
---

<a
	href={href}
	class="group block w-full max-w-sm overflow-hidden rounded-xl bg-white shadow-md transition-shadow hover:shadow-lg"
>
	<div class="flex h-40 items-center justify-center bg-cream p-6">
		<img
			src={imageUrl}
			alt={`${name} Logo`}
			class="max-h-full max-w-full object-contain transition-transform group-hover:scale-105"
		/>
	</div>
	<div class="px-4 py-4 text-center">
		<h3 class="font-heading text-lg font-semibold text-text">{name}</h3>
		<span
			class="mt-1 inline-block text-sm font-medium text-primary transition-colors group-hover:text-primary-light"
		>
			{linkLabel} &rarr;
		</span>
	</div>
</a>
