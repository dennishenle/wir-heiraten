---
import HeartDivider from "../love-story/HeartDivider.astro";
import RegistryCard from "./RegistryCard.astro";
import { registries } from "./registries";
---

<section id="registry" class="section-padding bg-cream-dark">
	<div class="mx-auto max-w-5xl">
		<h2 class="section-title">Geschenke</h2>
		<p class="mx-auto mb-4 max-w-xl text-center text-text-light">
			Wer uns eine Freude machen möchte, findet hier ein paar
			Inspirationen.
		</p>

		<HeartDivider />

		<div class="flex flex-wrap justify-center gap-8">
			{registries.map((reg) => <RegistryCard {...reg} />)}
		</div>
	</div>
</section>
