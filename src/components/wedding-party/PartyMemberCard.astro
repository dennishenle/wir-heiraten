---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
	name: string;
	description: string;
	image: ImageMetadata;
	alt: string;
}

const { name, description, image, alt } = Astro.props;
---

<div class="flex flex-col items-center text-center">
	<Image
		src={image}
		alt={alt}
		width="128"
		height="128"
		loading="lazy"
		decoding="async"
		class="mb-4 h-32 w-32 shrink-0 rounded-full object-cover shadow-md ring-2 ring-primary/15"
	/>
	<h3 class="font-heading text-lg font-semibold text-text">{name}</h3>
	<p class="mt-1 max-w-56 text-sm leading-snug text-text-light">
		{description}
	</p>
</div>
