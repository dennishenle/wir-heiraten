---
import HeartDivider from "../love-story/HeartDivider.astro";
import PartyMemberCard from "./PartyMemberCard.astro";
import { bridesmaid, groomsman } from "./witnesses";
---

<section id="party" class="section-padding bg-cream">
	<div class="mx-auto max-w-5xl">
		<h2 class="section-title">Unsere Trauzeugen</h2>
		<p class="mx-auto mb-4 max-w-xl text-center text-text-light">
			Die, die uns am nächsten stehen und uns an diesem Tag unterstützen.
		</p>

		<HeartDivider />

		<div class="space-y-16">
			<div>
				<h3
					class="mb-8 text-center font-heading text-xl font-semibold text-primary"
				>
					Trauzeugin der Braut
				</h3>
				<center>
					<PartyMemberCard {...bridesmaid} />
				</center>
			</div>

			<div>
				<h3
					class="mb-8 text-center font-heading text-xl font-semibold text-primary"
				>
					Trauzeuge des Bräutigams
				</h3>
				<center>
					<PartyMemberCard {...groomsman} />
				</center>
			</div>
		</div>
	</div>
</section>
