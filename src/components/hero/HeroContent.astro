	<p
		class="mb-4 text-sm font-light uppercase tracking-[0.3em] text-white/80 md:text-base"
	>
		Wir heiraten!
	</p>

	<h1
		class="font-heading text-5xl font-bold leading-tight md:text-7xl lg:text-8xl"
	>
		Svenja <span class="font-light italic">&</span> Dennis
	</h1>

	<p
		class="mt-4 text-lg font-light tracking-wide text-white/90 md:text-xl"
	>
		29. August 2026 &middot; Gundelfingen
	</p>

	<div class="mx-auto mt-10 h-px w-24 bg-white/40"></div>

	<HeroCountdown />
</div>
